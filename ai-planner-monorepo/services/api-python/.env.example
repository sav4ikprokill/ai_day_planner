APP_NAME=AI Day Planner
ENV=development
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/ai_planner
# Render may provide postgresql://... and the API normalizes it to postgresql+asyncpg://...
SCHEDULER_URL=http://scheduler-cpp:8080/optimize
ALLOW_DEV_INIT_DATA_BYPASS=false
# Set true only for demo mode with one shared demo user in ENV=development or ENV=staging.
GEMINI_API_KEY=
TELEGRAM_BOT_TOKEN=
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
